rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Product images: any authenticated user can read
    // Only the owning supplier can upload (path includes their uid)
    match /products/{supplierId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == supplierId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
